# Copy to .env. 打单/发货项目，使用库 dian_ship_db

SECRET_KEY=your-secret-key
DEBUG=True
# 通过公网 IP 访问时，把服务器公网 IP 加进来，例如：ALLOWED_HOSTS=localhost,127.0.0.1,1.2.3.4
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=dian_ship_db
DB_USER=dian
DB_PASSWORD=your-dian-password
DB_HOST=127.0.0.1
DB_PORT=3306

CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# Image 服务 OSS（实现 image/services 中 _upload_to_oss 等时使用）
# OSS_BUCKET_NAME=your-bucket
# OSS_REGION=cn-hangzhou
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_USE_SSL=True
